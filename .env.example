# ============================================================
#  pochaco 환경 설정 파일
#  cp .env.example .env 후 실제 값 입력
# ============================================================

# ────────────────────────────────────────────────────────────
#  빗썸 API 키 (필수)
# ────────────────────────────────────────────────────────────
BITHUMB_API_KEY=your_bithumb_api_key
BITHUMB_SECRET_KEY=your_bithumb_secret_key

# ────────────────────────────────────────────────────────────
#  LLM 공급자 선택 (필수)
#  "anthropic" | "openai" | "gemini" 중 하나만 입력
# ────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-opus-4-6

# ── OpenAI (ChatGPT) ─────────────────────────────────────────
# LLM_PROVIDER=openai 로 변경 시 아래 키 필요
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ── Google Gemini ────────────────────────────────────────────
# LLM_PROVIDER=gemini 로 변경 시 아래 키 필요
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# ────────────────────────────────────────────────────────────
#  데이터베이스 (EC2 환경)
#  옵션 A: SQLite (기본, 소규모 운영에 충분)
#    - DATABASE_URL 비워두면 자동 사용
#    - EC2 재시작 후 데이터 유지: EBS 볼륨에 마운트된 경로 사용 권장
# ────────────────────────────────────────────────────────────
# DATABASE_URL=                               # 비워두면 SQLite 사용
DB_PATH=/opt/pochaco/data/pochaco.db         # SQLite 절대경로

#  옵션 B: PostgreSQL (고가용성, RDS 사용 권장)
#    - DATABASE_URL 을 설정하면 SQLite 대신 사용됨
# DATABASE_URL=postgresql+psycopg2://user:password@your-rds-endpoint:5432/pochaco

# 백업 설정 (SQLite 전용, 매일 23:50 자동 실행)
DB_BACKUP_DIR=/opt/pochaco/backup
DB_BACKUP_KEEP_DAYS=7

# ────────────────────────────────────────────────────────────
#  거래 설정 (선택, 기본값 있음)
# ────────────────────────────────────────────────────────────
MIN_ORDER_KRW=5000              # 최소 주문금액
POSITION_CHECK_INTERVAL=10      # 포지션 감시 주기(초)

# ────────────────────────────────────────────────────────────
#  텔레그램 봇 (선택)
#  1. @BotFather 에서 봇 생성 → BOT_TOKEN 발급
#  2. 봇에게 메시지 전송 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
# ────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ────────────────────────────────────────────────────────────
#  웹 대시보드 (선택)
#  서버에서 http://<서버IP>:8080 으로 접속
#  EC2 보안그룹에서 8080 포트를 열어야 합니다
# ────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# ────────────────────────────────────────────────────────────
#  로깅
# ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/opt/pochaco/logs/pochaco.log
